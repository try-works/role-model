{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "endpoint-identity.schema.json",
  "title": "EndpointIdentity",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "endpoint_id",
    "endpoint_kind",
    "provider_kind",
    "serving_source",
    "model_id",
    "runtime_version"
  ],
  "properties": {
    "endpoint_id": { "type": "string" },
    "endpoint_kind": {
      "type": "string",
      "enum": ["local_engine", "remote_api", "browser_engine", "dispatch_adapter"]
    },
    "provider_kind": {
      "type": "string",
      "enum": [
        "acp",
        "mcp",
        "cli",
        "remote_openai_compat",
        "onnx",
        "mlx",
        "litertlm",
        "gguf",
        "webllm",
        "mediapipe_genai",
        "mediapipe_text"
      ]
    },
    "serving_source": { "type": "string" },
    "model_id": { "type": "string" },
    "package_id": { "type": "string" },
    "variant_id": { "type": "string" },
    "runtime_version": { "type": "string" },
    "quantization": { "type": "string" },
    "precision": { "type": "string" },
    "host_class": { "type": "string" },
    "device_class": { "type": "string" },
    "region": { "type": "string" },
    "org_scope": { "type": "string" },
    "endpoint_version": { "type": "string" }
  }
}
