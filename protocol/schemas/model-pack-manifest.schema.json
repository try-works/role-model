{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "model-pack-manifest.schema.json",
  "title": "ModelPackManifest",
  "type": "object",
  "additionalProperties": false,
  "required": ["pack_id", "version", "models"],
  "properties": {
    "pack_id": { "type": "string" },
    "version": { "type": "string" },
    "models": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["model_id", "artifact_ref"],
        "properties": {
          "model_id": { "type": "string" },
          "artifact_ref": { "type": "string" }
        }
      }
    }
  }
}
