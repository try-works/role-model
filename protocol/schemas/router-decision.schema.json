{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "router-decision.schema.json",
  "title": "RouterDecision",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "routing_decision_id",
    "request_id",
    "app_id",
    "org_id",
    "policy_snapshot",
    "eligibility",
    "scored_candidates",
    "chosen_endpoint_id",
    "fallback_endpoint_ids",
    "selection_reasons",
    "used_measured",
    "used_declared",
    "scoring_version"
  ],
  "properties": {
    "routing_decision_id": { "type": "string" },
    "request_id": { "type": "string" },
    "app_id": { "type": "string" },
    "org_id": { "type": ["string", "null"] },
    "policy_snapshot": { "$ref": "./routing-policy.schema.json" },
    "eligibility": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["endpoint_id", "eligible", "exclusions"],
        "properties": {
          "endpoint_id": { "type": "string" },
          "eligible": { "type": "boolean" },
          "exclusions": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["code", "detail"],
              "properties": {
                "code": {
                  "type": "string",
                  "enum": [
                    "CAPABILITY_MISSING",
                    "FORBIDDEN_CAPABILITY_PRESENT",
                    "MODALITY_UNSUPPORTED",
                    "CONTEXT_TOO_SMALL",
                    "TOOLS_UNSUPPORTED",
                    "ROLE_NOT_ALLOWED",
                    "TASK_NOT_SUPPORTED_BY_ROLE",
                    "ROLE_BINDING_INACTIVE",
                    "ROLE_BINDING_DISABLED",
                    "ROLE_BINDING_TASK_NOT_ALLOWED",
                    "ROLE_BINDING_CAPABILITY_MISSING",
                    "POLICY_DENY_ENDPOINT",
                    "POLICY_DENY_REMOTE",
                    "ACCOUNT_DISABLED",
                    "AUTH_UNAVAILABLE",
                    "ENTITLEMENT_MISSING",
                    "QUOTA_EXHAUSTED",
                    "REGION_DISALLOWED",
                    "DEPLOYMENT_CLASS_MISMATCH",
                    "PACKAGE_NOT_INSTALLED",
                    "VARIANT_INCOMPATIBLE",
                    "PROVIDER_OFFLINE",
                    "BUDGET_EXCEEDED",
                    "REVOKED"
                  ]
                },
                "detail": { "type": "string" }
              }
            }
          }
        }
      }
    },
    "scored_candidates": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["endpoint_id", "total_score", "metric_breakdown", "tie_break"],
        "properties": {
          "endpoint_id": { "type": "string" },
          "total_score": { "type": "number" },
          "metric_breakdown": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "quality",
              "latency",
              "throughput",
              "cost",
              "reliability",
              "preference"
            ],
            "properties": {
              "quality": { "$ref": "#/$defs/metricEntry" },
              "latency": { "$ref": "#/$defs/metricEntry" },
              "throughput": { "$ref": "#/$defs/metricEntry" },
              "cost": { "$ref": "#/$defs/metricEntry" },
              "reliability": { "$ref": "#/$defs/metricEntry" },
              "preference": { "$ref": "#/$defs/metricEntry" }
            }
          },
          "tie_break": {
            "type": "object",
            "additionalProperties": false,
            "required": ["quality", "latency_ms", "reliability", "endpoint_id"],
            "properties": {
              "quality": { "type": "number" },
              "latency_ms": { "type": "number", "minimum": 0 },
              "reliability": { "type": "number" },
              "endpoint_id": { "type": "string" }
            }
          }
        }
      }
    },
    "chosen_endpoint_id": { "type": "string" },
    "fallback_endpoint_ids": { "type": "array", "items": { "type": "string" } },
    "selection_reasons": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "BEST_TOTAL_SCORE",
          "MEASURED_PROFILE_USED",
            "DECLARED_PROFILE_USED",
            "DEFAULT_PROFILE_USED",
            "LOCAL_PREFERENCE_APPLIED",
            "REMOTE_PREFERENCE_APPLIED",
            "CONTINUITY_AFFINITY_APPLIED",
            "CACHE_AFFINITY_APPLIED",
            "ROUTING_MODEL_PREFERENCE_APPLIED",
            "BUDGET_OPTIMIZATION",
            "LOW_LATENCY_TARGET_MET",
            "HIGH_QUALITY_TARGET_MET",
          "ROLE_POLICY_APPLIED",
          "TASK_POLICY_APPLIED",
          "FALLBACK_CHAIN_COMPUTED"
        ]
      }
    },
    "used_measured": { "type": "boolean" },
    "used_declared": { "type": "boolean" },
    "scoring_version": { "type": "string" }
  },
  "$defs": {
    "metricEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["value", "source"],
      "properties": {
        "value": { "type": "number", "minimum": 0, "maximum": 1 },
        "source": {
          "type": "string",
          "enum": ["measured", "declared", "default"]
        },
        "raw": {
          "type": "object",
          "additionalProperties": true
        }
      }
    }
  }
}
