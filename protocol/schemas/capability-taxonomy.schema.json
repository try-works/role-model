{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "capability-taxonomy.schema.json",
  "title": "CapabilityTaxonomy",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "capabilities"],
  "properties": {
    "version": { "type": "string" },
    "capabilities": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "family", "description"],
        "properties": {
          "id": { "type": "string" },
          "family": { "type": "string" },
          "description": { "type": "string" }
        }
      }
    }
  }
}
