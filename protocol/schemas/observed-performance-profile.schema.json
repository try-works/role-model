{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ObservedPerformanceProfile",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "endpoint_id",
    "measured_at_ms",
    "sample_window",
    "sample_size",
    "sources",
    "latency_ms_p50",
    "latency_ms_p95",
    "failure_rate",
    "freshness_score",
    "confidence_score"
  ],
  "properties": {
    "endpoint_id": { "type": "string" },
    "measured_at_ms": { "type": "integer", "minimum": 0 },
    "sample_window": {
      "type": "object",
      "additionalProperties": false,
      "required": ["started_at_ms", "ended_at_ms"],
      "properties": {
        "started_at_ms": { "type": "integer", "minimum": 0 },
        "ended_at_ms": { "type": "integer", "minimum": 0 }
      }
    },
    "sample_size": { "type": "integer", "minimum": 1 },
    "sources": {
      "type": "object",
      "additionalProperties": false,
      "required": ["live_request_samples", "benchmark_samples"],
      "properties": {
        "live_request_samples": { "type": "integer", "minimum": 0 },
        "benchmark_samples": { "type": "integer", "minimum": 0 }
      }
    },
    "judge_score": { "type": "number" },
    "latency_ms_p50": { "type": "number", "minimum": 0 },
    "latency_ms_p95": { "type": "number", "minimum": 0 },
    "tokens_per_sec": { "type": "number", "minimum": 0 },
    "cold_start_ms": { "type": "number", "minimum": 0 },
    "failure_rate": { "type": "number", "minimum": 0, "maximum": 1 },
    "error_class_rates": {
      "type": "object",
      "additionalProperties": { "type": "number", "minimum": 0, "maximum": 1 }
    },
    "cost_per_1k_tokens_est": { "type": "number", "minimum": 0 },
    "currency": { "type": "string" },
    "quality_score": { "type": "number", "minimum": 0, "maximum": 1 },
    "freshness_score": { "type": "number", "minimum": 0, "maximum": 1 },
    "confidence_score": { "type": "number", "minimum": 0, "maximum": 1 }
  }
}
