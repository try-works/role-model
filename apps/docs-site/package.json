    "managedPaths": [
      ".gitignore",
      "app/app.css",
      "app/components",
      "app/lib/cn.ts",
      "app/lib/layout.shared.tsx",
      "app/lib/source.ts",
      "app/llms",
      "app/root.tsx",
      "app/routes/search.ts",
      "public",
      "serve.json",
      "source.config.ts",
      "tsconfig.json",
      "vite.config.ts"
    ]
  },
  "scripts": {
    "build": "react-router build && npm run types:check && node ./scripts/materialize-search-index.mjs",
    "dev": "react-router dev",
    "pages:create": "wrangler pages project create role-model-dev --production-branch main --compatibility-date 2026-05-04",
    "pages:dev": "npm run build && wrangler pages dev ./build/client",
    "pages:deploy": "npm run build && wrangler pages deploy ./build/client --project-name role-model-dev",
    "start": "serve ./build/client --config ./serve.json",
    "types:check": "react-router typegen && fumadocs-mdx && tsc --noEmit",
    "upstream:sync": "node ./scripts/upstream-sync.mjs --write",
    "upstream:sync:latest": "node ./scripts/upstream-sync.mjs --write --ref main"
  },
  "dependencies": {
    "@orama/orama": "^3.1.18",
    "@react-router/node": "^7.14.2",
    "fumadocs-core": "^16.8.7",
